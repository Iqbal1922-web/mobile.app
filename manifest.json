{
  "id": "myschedule-app",
  "name": "MySchedule - Jadwal Kuliah Pintar",
  "short_name": "MySchedule",
  "description": "Aplikasi untuk mengelola jadwal kuliah secara praktis, offline, dan dapat diinstall seperti aplikasi mobile.",

  "start_url": "./index.html?source=pwa",
  "scope": "./",
  "display": "standalone",
  "background_color": "#6366f1",
  "theme_color": "#6366f1",
  "orientation": "portrait",

  "icons": [
    {
      "src": "icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],

  "categories": ["productivity", "education"],

  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".txt"]
      }
    }
  ],

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "protocol_handlers": [
    {
      "protocol": "web+myschedule",
      "url": "./index.html"
    }
  ],

  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "widgets": [
    {
      "name": "MySchedule Widget",
      "short_name": "Schedule",
      "description": "Lihat jadwal cepat",
      "tag": "myschedule-widget",
      "icons": [
        {
          "src": "icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],

  "edge_side_panel": {
    "preferred_width": 400
  },

  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "icons/screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],

  "shortcuts": [
    {
       "name": "Tambah Jadwal",
    "short_name": "Tambah",
    "description": "Tambah jadwal kuliah baru",
    "url": "./index.html",
    "icons": [
      {
        "src": "icons/icon-192x192.png",
        "sizes": "192x192",
        "type": "image/png"
        }
      ]
    }
  ],

  "lang": "id",
  "dir": "ltr",

  "display_override": ["window-controls-overlay", "standalone"],

  "prefer_related_applications": false,

  "related_applications": [
    {
      "platform": "webapp",
      "url": "./index.html"
    }
  ],

  "iarc_rating_id": "e",

  "scope_extensions": [
    {
      "origin": "./"
    }
  ],

  "note_taking": {
    "new_note_url": "./index.html"
  }
}